# Use the last part of the current directory as the Ghostty tab/window title.
__set_ghostty_title() {
  [[ ${TERM_PROGRAM:-} == "ghostty" || -n ${GHOSTTY_RESOURCES_DIR:-} ]] || return

  local title="${PWD##*/}"
  [[ -n "$title" ]] || title="/"

  printf '\033]2;%s\007' "$title"
}

if [[ "$(declare -p PROMPT_COMMAND 2>/dev/null)" == declare\ -[aA]* ]]; then
  PROMPT_COMMAND+=(__set_ghostty_title)
else
  PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND;}__set_ghostty_title"
fi

