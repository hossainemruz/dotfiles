# If not running interactively, don't do anything (leave this at the top of this file)
[[ $- != *i* ]] && return

# All the default Omarchy aliases and functions, when available.
if [[ -r "$HOME/.local/share/omarchy/default/bash/rc" ]]; then
  source "$HOME/.local/share/omarchy/default/bash/rc"
fi

# Homebrew shellenv for macOS interactive shells.
if [[ "$(uname -s)" == "Darwin" ]]; then
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

# Source autojump
if [[ -s /usr/share/autojump/autojump.bash ]]; then
  source /usr/share/autojump/autojump.bash
elif command -v brew >/dev/null 2>&1 && [[ -s "$(brew --prefix)/etc/profile.d/autojump.sh" ]]; then
  source "$(brew --prefix)/etc/profile.d/autojump.sh"
fi

# Add your own exports, aliases, and functions here.

# environment variables
export GOPRIVATE=github.com/qdrant
export PATH="$HOME/.local/bin:$PATH"

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash)"
fi

# Use the last part of the current directory as the Ghostty tab/window title.
__set_ghostty_title() {
  [[ ${TERM_PROGRAM:-} == "ghostty" || -n ${GHOSTTY_RESOURCES_DIR:-} ]] || return

  local title="${PWD##*/}"
  [[ -n "$title" ]] || title="/"

  printf '\033]2;%s\007' "$title"
}

if [[ "$(declare -p PROMPT_COMMAND 2>/dev/null)" == declare\ -[aA]* ]]; then
  PROMPT_COMMAND+=(__set_ghostty_title)
else
  PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND;}__set_ghostty_title"
fi

# Start ssh-agent if is not running already. macOS normally provides this via
# launchd/keychain, so avoid starting a nested agent there.
if [ -z "${SSH_AUTH_SOCK:-}" ] && [[ "$(uname -s)" != "Darwin" ]]; then
  eval "$(ssh-agent -s)" >/dev/null
fi

