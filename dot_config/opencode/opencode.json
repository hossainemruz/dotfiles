{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "edit": {
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny"
    },
    "bash": {
      "rm *credentials*": "deny",
      "rm *.env*": "deny"
    }
  },
  "model": "opencode-go/minimax-m2.7",
  "default_agent": "general",
  "agent": {
    "build": {
      "description": "Primary coding agent",
      "hidden": true,
      "model": "opencode-go/kimi-k2.5",
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "plan": {
      "description": "Structured implementation planning",
      "model": "github-copilot/gpt-5.4",
      "prompt": "{file:./prompts/plan-guideline.md}"
    },
    "explore": {
      "description": "Fast codebase exploration",
      "model": "opencode-go/minimax-m2.7",
      "prompt": "{file:./prompts/explore-guideline.md}"
    },
    "general": {
      "description": "General-purpose default agent",
      "mode": "primary",
      "model": "opencode-go/minimax-m2.7",
      "prompt": "{file:./prompts/general-guideline.md}"
    },
    "kimi": {
      "description": "Building with Kimi",
      "model": "opencode-go/kimi-k2.5",
      "mode": "primary",
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "GLM": {
      "description": "Building with GLM",
      "model": "opencode-go/glm-5.1",
      "mode": "primary",
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "GPT": {
      "description": "Building with GPT",
      "model": "github-copilot/gpt-5.4",
      "mode": "primary",
      "prompt": "{file:./prompts/coding-guideline.md}"
    }
  },
  "plugin": [
    "@plannotator/opencode@v0.17.10"
  ]
}
