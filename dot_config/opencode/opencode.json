{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "enabled_providers": [
    "deepseek",
    "openai"
  ],
  "provider": {
    "openai": {
      "options": {
        "setCacheKey": true
      }
    }
  },
  "instructions": [
    "./prompts/task-artifact-gate.md"
  ],
  "lsp": true,
  "mcp": {
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ]
    },
    "ast-grep": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp@732c339c3812a44e9111e6c3aefec64894acd58f",
        "ast-grep-server"
      ]
    }
  },
  "small_model": "deepseek/deepseek-v4-flash",
  "permission": {
    "read": {
      "~/.ssh/*": "deny",
      "~/.gnupg/*": "deny",
      "~/.aws/*": "deny",
      "~/.azure/*": "deny",
      "~/.kube/*": "deny",
      "~/.docker/*": "deny",
      "~/.config/gcloud/*": "deny",
      ".env*": "deny",
      "*/.env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "edit": {
      "~/.aws/*": "deny",
      "~/.azure/*": "deny",
      "~/.ssh/*": "deny",
      "~/.gnupg/*": "deny",
      "~/.kube/*": "deny",
      "~/.docker/*": "deny",
      "~/.config/gcloud/*": "deny",
      ".env*": "deny",
      "*/.env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "external_directory": {
      "/tmp": "allow",
      "~/agent-vault": "allow",
      "~/agent-vault/*": "allow"
    },
    "skill": {
      "omarchy": "deny",
      "plannotator-*": "deny"
    },
    "bash": {
      "curl *": "ask",
      "wget *": "ask",
      "ssh *": "ask",
      "scp *": "ask",
      "git push *": "ask",
      "brew install *": "ask",
      "npm publish *": "ask",
      "*.env*": "deny",
      "*.pem*": "deny",
      "*.key*": "deny",
      "*.p12*": "deny",
      "*.jks*": "deny",
      "*/.ssh/*": "deny",
      "*/.gnupg/*": "deny",
      "*/.aws/*": "deny",
      "*/.azure/*": "deny",
      "*/.kube/*": "deny",
      "*/.docker/*": "deny",
      "*/.config/gcloud/*": "deny",
      "rm *": "ask",
      "sudo rm *": "ask",
      "chmod -R *": "ask",
      "chmod 000 *": "ask",
      "chmod 0 *": "ask",
      "chown *": "ask",
      "sudo chown *": "ask",
      "dd *": "ask",
      "mkfs*": "ask",
      "shutdown*": "ask",
      "reboot*": "ask",
      "halt*": "ask",
      "poweroff*": "ask",
      "init 0*": "ask",
      "init 6*": "ask",
      "killall *": "ask",
      "pkill *": "ask",
      "kill -9 *": "ask",
      "git push --force*": "ask",
      "git push -f*": "ask",
      "git reset --hard*": "ask",
      "git clean -f*": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask"
    }
  },
  "model": "openai/gpt-5.6-terra",
  "default_agent": "general",
  "experimental": {
    "disable_paste_summary": true
  },
  "tool_output": {
    "max_lines": 120,
    "max_bytes": 12000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 6,
    "preserve_recent_tokens": 8000
  },
  "agent": {
    "general": {
      "description": "Primary orchestrator for normal use, delegation, planning handoff, and review handoff",
      "model": "openai/gpt-5.6-terra",
      "mode": "primary",
      "variant": "xhigh",
      "permission": {
        "task": {
          "*": "deny",
          "plan": "allow",
          "explore": "allow",
          "executor": "allow",
          "build": "allow",
          "simplifier": "allow",
          "reviewer": "allow",
          "expert-reviewer": "allow"
        }
      },
      "prompt": "{file:./prompts/general-guideline.md}\n\n{file:./prompts/tool-routing.md}"
    },
    "build": {
      "description": "Primary coding agent that delegates execution and review",
      "model": "openai/gpt-5.6-terra",
      "variant": "high",
      "permission": {
        "external_directory": {
          "/tmp/*": "allow"
        },
        "task": {
          "*": "deny",
          "explore": "allow",
          "executor": "allow",
          "reviewer": "allow"
        }
      },
      "prompt": "{file:./prompts/coding-guideline.md}\n\n{file:./prompts/tool-routing.md}"
    },
    "plan": {
      "description": "Primary research and structured implementation planning agent",
      "model": "openai/gpt-5.6-sol",
      "variant": "high",
      "permission": {
        "edit": {
          "*": "deny",
          ".work/*": "allow",
          "~/agent-vault": "allow",
          "~/agent-vault/*": "allow"
        },
        "task": {
          "*": "deny",
          "explore": "allow",
          "executor": "allow"
        }
      },
      "prompt": "{file:./skills/planning/SKILL.md}"
    },
    "explore": {
      "description": "Semantic codebase exploration",
      "model": "deepseek/deepseek-v4-pro",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": "deny",
        "task": "deny"
      },
      "prompt": "{file:./prompts/explore-guideline.md}\n\n{file:./prompts/tool-routing.md}"
    },
    "executor": {
      "description": "Default execution subagent for bash commands, tests, builds, and validation",
      "model": "deepseek/deepseek-v4-flash",
      "mode": "subagent",
      "hidden": true,
      "steps": 4,
      "permission": {
        "edit": "deny",
        "task": "deny",
        "external_directory": {
          "/tmp/*": "allow"
        }
      },
      "prompt": "{file:./prompts/executor-guideline.md}"
    },
    "simplifier": {
      "description": "Review changed code for reuse, quality, and efficiency, then fix worthwhile issues",
      "model": "openai/gpt-5.6-terra",
      "variant": "high",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "task": {
          "*": "deny",
          "executor": "allow"
        }
      },
      "prompt": "{file:./skills/simplify/SKILL.md}"
    },
    "reviewer": {
      "description": "Automated risk-adaptive multi-pass code review agent",
      "model": "openai/gpt-5.6-terra",
      "variant": "high",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".work/*": "allow",
          "~/agent-vault": "allow",
          "~/agent-vault/*": "allow"
        },
        "task": "deny"
      },
      "prompt": "{file:./skills/code-review/SKILL.md}"
    },
    "expert-reviewer": {
      "description": "In-depth final review with premium model",
      "model": "openai/gpt-5.6-sol",
      "variant": "high",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".work/*": "allow",
          "~/agent-vault": "allow",
          "~/agent-vault/*": "allow"
        },
        "task": {
          "*": "deny",
          "executor": "allow"
        }
      },
      "prompt": "{file:./prompts/expert-reviewer-guideline.md}"
    }
  }
}
