{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "**/.env*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.jks": "deny",
      "**/*.jks": "deny",
      "*credentials*": "deny",
      "**/*credentials*": "deny"
    },
    "edit": {
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "**/.env*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.jks": "deny",
      "**/*.jks": "deny",
      "*credentials*": "deny",
      "**/*credentials*": "deny"
    },
    "bash": {
      "*": "ask",
      "*.env*": "deny",
      "*.pem*": "deny",
      "*.key*": "deny",
      "*.p12*": "deny",
      "*.jks*": "deny",
      "*/.ssh/*": "deny",
      "*/.gnupg/*": "deny",
      "*/.aws/*": "deny",
      "*/.azure/*": "deny",
      "*/.kube/*": "deny",
      "*/.docker/*": "deny",
      "*/.config/gcloud/*": "deny"
    }
  },
  "model": "opencode-go/deepseek-v4-flash",
  "default_agent": "general",
  "experimental": {
    "disable_paste_summary": true
  },
  "tool_output": {
    "max_lines": 120,
    "max_bytes": 12000
  },
  "compaction": {
    "auto": true,
    "tail_turns": 12
  },
  "agent": {
    "general": {
      "description": "Cheap primary orchestrator for normal use, planning handoff, and final review handoff",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "primary",
      "permission": {
        "bash": "deny",
        "task": "allow"
      },
      "prompt": "{file:./prompts/general-guideline.md}"
    },
    "build": {
      "description": "Primary coding agent that delegates execution and review",
      "model": "opencode-go/kimi-k2.6",
      "mode": "all",
      "permission": {
        "external_directory": {
          "/tmp": "allow",
          "/tmp/**": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "plan": {
      "description": "Structured implementation planning",
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "bash": "deny",
        "edit": {
          "*": "deny",
          ".opencode/*": "allow",
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/plan-guideline.md}"
    },
    "explore": {
      "description": "Fast codebase exploration",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "task": "deny"
      },
      "prompt": "{file:./prompts/explore-guideline.md}"
    },
    "executor": {
      "description": "Default execution subagent for bash commands, tests, builds, and validation",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "external_directory": {
          "/tmp": "allow",
          "/tmp/**": "allow"
        },
        "task": "deny"
      },
      "prompt": "{file:./prompts/executor-guideline.md}"
    },
    "reviewer": {
      "description": "Automated review agent",
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/*": "allow",
        },
        "task": "deny"
      },
      "prompt": "Use code-review skill. Review only the changed scope and write findings to .opencode/review.md."
    },
    "expert-reviewer": {
      "description": "In-depth review with premium model",
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/*": "allow",
        },
        "task": "deny"
      },
      "prompt": "Use code-review skill. Perform a final in-depth review of the full diff against the task and plan, and write findings to .opencode/review.md."
    }
  }
}
