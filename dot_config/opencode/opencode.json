{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "enabled_providers": [
    "deepseek",
    "openai"
  ],
  "instructions": [
    "/home/emruz/.config/agent-workflows/task-artifacts.md"
  ],
  "lsp": true,
  "mcp": {
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ],
      "enabled": true
    },
    "ast-grep": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ],
      "enabled": true
    }
  },
  "small_model": "deepseek/deepseek-v4-flash",
  "permission": {
    "read": {
      "/home/emruz/agent-vault": "allow",
      "/home/emruz/agent-vault/**": "allow",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "**/.env*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.jks": "deny",
      "**/*.jks": "deny",
      "*credentials*": "deny",
      "**/*credentials*": "deny"
    },
    "edit": {
      "/home/emruz/agent-vault": "allow",
      "/home/emruz/agent-vault/**": "allow",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "**/.env*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.jks": "deny",
      "**/*.jks": "deny",
      "*credentials*": "deny",
      "**/*credentials*": "deny"
    },
    "external_directory": {
      "/home/emruz/agent-vault": "allow",
      "/home/emruz/agent-vault/**": "allow"
    },
    "skill": {
      "omarchy": "deny",
      "plannotator-*": "deny"
    },
    "lsp": "allow",
    "bash": {
      "*": "allow",
      "*.env*": "deny",
      "*.pem*": "deny",
      "*.key*": "deny",
      "*.p12*": "deny",
      "*.jks*": "deny",
      "*/.ssh/*": "deny",
      "*/.gnupg/*": "deny",
      "*/.aws/*": "deny",
      "*/.azure/*": "deny",
      "*/.kube/*": "deny",
      "*/.docker/*": "deny",
      "*/.config/gcloud/*": "deny",
      "rm *": "ask",
      "sudo rm *": "ask",
      "chmod -R *": "ask",
      "chmod 000 *": "ask",
      "chmod 0 *": "ask",
      "chown *": "ask",
      "sudo chown *": "ask",
      "dd *": "ask",
      "mkfs*": "ask",
      "shutdown*": "ask",
      "reboot*": "ask",
      "halt*": "ask",
      "poweroff*": "ask",
      "init 0*": "ask",
      "init 6*": "ask",
      "killall *": "ask",
      "pkill *": "ask",
      "kill -9 *": "ask",
      "git push --force*": "ask",
      "git push -f*": "ask",
      "git reset --hard*": "ask",
      "git clean -f*": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask"
    }
  },
  "model": "deepseek/deepseek-v4-pro",
  "default_agent": "general",
  "experimental": {
    "disable_paste_summary": true
  },
  "tool_output": {
    "max_lines": 120,
    "max_bytes": 12000
  },
  "compaction": {
    "auto": true,
    "tail_turns": 18
  },
  "agent": {
    "general": {
      "description": "Primary orchestrator for normal use, delegation, planning handoff, and review handoff",
      "model": "openai/gpt-5.5",
      "mode": "primary",
      "variant": "medium",
      "permission": {
        "external_directory": {
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/general-guideline.md}\n\n{file:./prompts/tool-routing.md}"
    },
    "build": {
      "description": "Primary coding agent that delegates execution and review",
      "model": "deepseek/deepseek-v4-pro",
      "mode": "all",
      "permission": {
        "external_directory": {
          "/tmp": "allow",
          "/tmp/**": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/coding-guideline.md}\n\n{file:./prompts/tool-routing.md}"
    },
    "plan": {
      "description": "Primary research and structured implementation planning agent",
      "model": "openai/gpt-5.5",
      "variant": "high",
      "permission": {
        "edit": {
          "*": "deny",
          ".work/*": "allow",
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "external_directory": {
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "task": "allow"
      },
      "prompt": "{skill:planning}"
    },
    "explore": {
      "description": "Semantic codebase exploration",
      "model": "deepseek/deepseek-v4-pro",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "external_directory": {
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "edit": "deny",
        "task": "deny"
      },
      "prompt": "{file:./prompts/explore-guideline.md}\n\n{file:./prompts/tool-routing.md}"
    },
    "executor": {
      "description": "Default execution subagent for bash commands, tests, builds, and validation",
      "model": "deepseek/deepseek-v4-flash",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": "deny",
        "task": "deny",
        "external_directory": {
          "/tmp": "allow",
          "/tmp/**": "allow",
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        }
      },
      "prompt": "{file:./prompts/executor-guideline.md}"
    },
    "simplifier": {
      "description": "Review changed code for reuse, quality, and efficiency, then fix worthwhile issues",
      "model": "deepseek/deepseek-v4-pro",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "external_directory": {
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "task": "allow"
      },
      "prompt": "{skill:simplify}"
    },
    "reviewer": {
      "description": "Automated risk-adaptive multi-pass code review agent",
      "model": "deepseek/deepseek-v4-pro",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".work/*": "allow",
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "external_directory": {
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "task": "deny"
      },
      "prompt": "{skill:code-review}"
    },
    "expert-reviewer": {
      "description": "In-depth final review with premium model",
      "model": "openai/gpt-5.5",
      "variant": "high",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".work/*": "allow",
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "external_directory": {
          "/home/emruz/agent-vault": "allow",
          "/home/emruz/agent-vault/**": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/expert-reviewer-guideline.md}"
    }
  }
}
