{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "**/.env*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.jks": "deny",
      "**/*.jks": "deny",
      "*credentials*": "deny",
      "**/*credentials*": "deny"
    },
    "edit": {
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "**/.env*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.jks": "deny",
      "**/*.jks": "deny",
      "*credentials*": "deny",
      "**/*credentials*": "deny"
    },
    "bash": {
      "*": "allow",
      "*.env*": "deny",
      "*.pem*": "deny",
      "*.key*": "deny",
      "*.p12*": "deny",
      "*.jks*": "deny",
      "*/.ssh/*": "deny",
      "*/.gnupg/*": "deny",
      "*/.aws/*": "deny",
      "*/.azure/*": "deny",
      "*/.kube/*": "deny",
      "*/.docker/*": "deny",
      "*/.config/gcloud/*": "deny",
      "rm *": "ask",
      "sudo rm *": "ask",
      "chmod -R *": "ask",
      "chmod 000 *": "ask",
      "chmod 0 *": "ask",
      "chown *": "ask",
      "sudo chown *": "ask",
      "dd *": "ask",
      "mkfs*": "ask",
      "shutdown*": "ask",
      "reboot*": "ask",
      "halt*": "ask",
      "poweroff*": "ask",
      "init 0*": "ask",
      "init 6*": "ask",
      "killall *": "ask",
      "pkill *": "ask",
      "kill -9 *": "ask",
      "git push --force*": "ask",
      "git push -f*": "ask",
      "git reset --hard*": "ask",
      "git clean -f*": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask"
    }
  },
  "model": "opencode-go/deepseek-v4-flash",
  "default_agent": "general",
  "experimental": {
    "disable_paste_summary": true
  },
  "tool_output": {
    "max_lines": 120,
    "max_bytes": 12000
  },
  "compaction": {
    "auto": true,
    "tail_turns": 18
  },
  "agent": {
    "general": {
      "description": "Primary orchestrator for normal use, planning handoff, and final review handoff",
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "primary",
      "permission": {
        "task": "allow"
      },
      "prompt": "{file:./prompts/general-guideline.md}"
    },
    "build": {
      "description": "Primary coding agent that delegates execution and review",
      "model": "opencode-go/kimi-k2.6",
      "mode": "all",
      "permission": {
        "external_directory": {
          "/tmp": "allow",
          "/tmp/**": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "plan": {
      "description": "Structured implementation planning",
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/tasks/*": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/plan-guideline.md}\n\n{skill:planning}"
    },
    "explore": {
      "description": "Semantic codebase exploration",
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": "deny",
        "task": "deny"
      },
      "prompt": "{file:./prompts/explore-guideline.md}"
    },
    "executor": {
      "description": "Default execution subagent for bash commands, tests, builds, and validation",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "external_directory": {
          "/tmp": "allow",
          "/tmp/**": "allow"
        },
        "task": "deny"
      },
      "prompt": "{file:./prompts/executor-guideline.md}"
    },
    "simplifier": {
      "description": "Review changed code for reuse, quality, and efficiency, then fix worthwhile issues",
      "model": "opencode-go/kimi-k2.6",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "task": "allow"
      },
      "prompt": "{skill:simplify}"
    },
    "reviewer": {
      "description": "Automated code review agent with direct review for small diffs and parallel review for larger ones",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/tasks/*": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/reviewer-guideline.md}\n\n{skill:parallel-review}"
    },
    "expert-reviewer": {
      "description": "In-depth final review with premium model",
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".agents/tasks/*": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./prompts/expert-reviewer-guideline.md}"
    }
  }
}
