{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "edit": {
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny"
    },
    "bash": {
      "rm *credentials*": "deny",
      "rm *.env*": "deny"
    }
  },
  "model": "opencode-go/deepseek-v4-flash",
  "default_agent": "DS-Flash",
  "instructions": [
    "./prompts/general-guideline.md",
  ],
  "agent": {
    "build": {
      "description": "Primary coding agent",
      "hidden": true,
      "model": "opencode-go/kimi-k2.6",
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "plan": {
      "description": "Structured implementation planning",
      "hidden": true,
      "model": "github-copilot/gpt-5.4",
      "prompt": "{file:./prompts/plan-guideline.md}"
    },
    "explore": {
      "description": "Fast codebase exploration",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./prompts/explore-guideline.md}"
    },
    "Kimi": {
      "description": "Building with Kimi",
      "model": "opencode-go/kimi-k2.6",
      "mode": "primary",
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "DS-Pro": {
      "description": "DeepSeek V4 Pro",
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "primary",
      "variant": "max",
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "DS-Flash": {
      "description": "DeepSeek V4 Flash",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "primary",
      "variant": "max",
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "GPT": {
      "description": "Building with GPT",
      "model": "github-copilot/gpt-5.4",
      "mode": "primary",
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
  },
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwopus-glm-18b-merged": {
          "name": "Qwopus"
        }
      }
    },
  },
  "plugin": [
    "@plannotator/opencode@v0.19.7"
  ]
}
