layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    children
    pane size=1 borderless=true {
      plugin location="zellij:status-bar"
    }
  }
  tab name="IDE" focus=true {
    pane stacked=true {
      pane {
        name "Code"
        command "nvim"
        args "."
      }
      pane name="Terminal"
    }
  }
  tab name="OpenCode" {
    pane command="opencode"
  }
}
